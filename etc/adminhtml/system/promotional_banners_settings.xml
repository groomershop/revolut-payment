<?xml version="1.0"?>

<include xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_include.xsd">
    <group id="promotional_banners_settings" translate="label comment" type="text" sortOrder="5" showInDefault="1" showInWebsite="1" showInStore="1">
        <label>Promotional banners</label>
<field id="enable_informational_banner" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Enable Revolut informational Banner</label>
            <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
        </field>
        <field id="revolut_pay_title_banner" translate="label" type="select" sortOrder="1" showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Revolut Pay information</label>
            <source_model>Revolut\Payment\Model\Source\Banners</source_model>
        </field>
        <field id="promo_banner_preview"
            translate="label"
            type="note"
            sortOrder="100"
            showInDefault="1"
            showInWebsite="1"
            showInStore="1">
            <label>Merchant Affiliate Programme</label>
            <frontend_model>Revolut\Payment\Block\Adminhtml\System\Config\AffiliateBannerBlock</frontend_model>
        </field>
    </group>
</include>
