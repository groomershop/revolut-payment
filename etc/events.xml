<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="urn:magento:framework:Event/etc/events.xsd">
    <event name="payment_method_assign_data_revolut_card">
        <observer name="revolut_card_gateway_data_assign" instance="Revolut\Payment\Observer\DataAssignObserver" />
    </event>
    <event name="payment_method_assign_data_revolut_pay">
        <observer name="revolut_pay_gateway_data_assign" instance="Revolut\Payment\Observer\DataAssignObserver" />
    </event>
    <event name="payment_method_assign_data_revolut_payment_request">
        <observer name="revolut_payment_request_gateway_data_assign" instance="Revolut\Payment\Observer\DataAssignObserver" />
    </event>
    <event name="shortcut_buttons_container">
        <observer name="revolut_payments_request_buttons" instance="Revolut\Payment\Observer\AppendPaymentRequestButtonObserver"/>
    </event>
    <event name="sales_order_shipment_track_save_after">
        <observer name="revolut_payment_shipment_save_after" instance="Revolut\Payment\Observer\ShipmentSaveAfter"/>
    </event>
    <event name="sales_order_load_after">
        <observer name="revolut_payment_sales_order_load_after" instance="Revolut\Payment\Observer\SalesOrderLoadAfter"/>
    </event>
</config>
